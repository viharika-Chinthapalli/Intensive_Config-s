# =============================================================================
# Copy this file to `.env` in the same folder as `package.json` and fill in
# values locally. Do not commit `.env` or any service account JSON.
# =============================================================================

# Required locally: path to Google Cloud service account JSON (Sheets API).
# Can be absolute or relative to the directory you run `npm run dev:server` from
# (usually this project root).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Alternative (e.g. Render): full service account JSON on one line — run: jq -c . < secrets/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# API server port (Vite proxies /api here in dev)
PORT=8787

# --- Optional: Sheets / align tuning (defaults shown in server code) ---
# SHEETS_INTER_WORKBOOK_DELAY_MS=1100
# SHEETS_LINKED_MAX_ATTEMPTS=14
# SHEETS_LINKED_BASE_DELAY_MS=2400
# ALIGN_LOAD_ALL_SYLLABUS_WORKBOOKS=0
# MASTER_GRID_INCLUDE_CHUNK_ROWS=380
# SYLLABUS_CACHE_TTL_MS=21600000

# --- Optional: Anthropic (server only; never put API keys in the client) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MAX_ITEMS=72
# ANTHROPIC_MAX_CHARS_PER_SYLLABUS=3200
